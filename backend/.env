# সার্ভার কনফিগারেশন
PORT=5000
NODE_ENV=development

# ডাটাবেস (এখানে আপনার MongoDB এর লিংক বসবে)
MONGODB_URI=your_mongodb_connection_string_here

# ব্লকচেইন এপিআই (Alchemy থেকে পাওয়া কি এখানে বসবে)
ALCHEMY_API_KEY=your_alchemy_api_key_here

# টেলিগ্রাম বট (বটফাদার থেকে পাওয়া টোকেন এখানে বসবে)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# সিকিউরিটি (আপনার ইচ্ছামতো একটি লম্বা পাসওয়ার্ড বা সিক্রেট কি দিন)
JWT_SECRET=your_super_secret_jwt_key_12345
